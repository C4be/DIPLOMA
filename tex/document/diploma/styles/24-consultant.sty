        \fontsize{12pt}{16pt}\selectfont
        \noindent
        \textbf{Обучающийся} \uline{\hfill\@student\hfill} \\
        \textbf{Институт (Филиал)} \uline{\hspace{1cm}\@faculty\hfill} \textbf{Кафедра} \uline{\hspace{1cm}\@department\hfill} \\
        \textbf{Группа} \uline{\@group} \textbf{Направление подготовки} \expandafter\uline\expandafter{\expanded{\@speciality}\hfill} \\
        \textbf{\profileType} \uline{\hspace{1cm}\@profile\hfill} \\
        \textbf{Квалификация:} \uline{\textbf{\degree}\hfill} \\
        \textbf{Наименование темы:} \expandafter\uline\expandafter{\expanded{\@theme}\hfill} \\
        \textbf{Руководитель:} \expandafter\uline\expandafter{\expanded{\@supervisor}\hfill} \\
    \endgroup

    \vfill

    \noindent\expandafter\uline\expandafter{\expanded{Выпускная квалификационная работа обучающегося \@student\ на тему «\@theme» соответствует профилю подготовки и требованиям к оформлению материалов ВКР.\\В работе рассмотрена актуальная задача интерактивного анализа данных в реляционных базах данных с использованием больших языковых моделей и RAG-архитектуры.\\Материал изложен последовательно, результаты имеют практическую направленность и могут быть использованы при развитии программных средств анализа данных.}\hfill} \\
    \noindent\textbf{Заключение:}\uline{\hfill замечаний, препятствующих допуску к защите, нет \hfill} \\

    % Plagiarism check and conclusion
    \vfill
    \noindent \uline{\hspace{0.5cm}} \uline{\hspace{2cm}} \the\year\ \text{г.} \hfill \textbf{Консультант} \uline{\hspace{3cm}}

}

